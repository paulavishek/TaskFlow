# Environment Variables for API Cost Protection
# Add these to your .env file:

# Daily API spending limit (in USD)
DAILY_API_LIMIT=0.50

# Monthly API spending limit (in USD)  
MONTHLY_API_LIMIT=5.00

# Set to true to bypass limits in development (use carefully!)
BYPASS_API_LIMITS_DEV=false

# Enable development mode detection
DJANGO_DEVELOPMENT=true

# Gemini API key (make sure this is set)
GEMINI_API_KEY=your_actual_api_key_here
